# Database — defaults to local SQLite for instant MVP startup.
# Swap to Postgres by setting DATABASE_URL to a postgres:// URL and changing
# the provider in prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# NextAuth.js
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth — leave empty to disable the "Continue with Google" button.
#
# Setup:
#   1. https://console.cloud.google.com → APIs & Services → Credentials.
#   2. Create an OAuth 2.0 Client ID of type "Web application".
#   3. Authorized redirect URI:
#        http://localhost:3000/api/auth/callback/google     (dev)
#        https://<your-domain>/api/auth/callback/google     (prod)
#   4. Paste the Client ID and Secret below and restart the server.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic-link sign-in (optional)
#
# When EMAIL_SERVER + EMAIL_FROM are configured, "Email me a sign-in link" on
# the login page delivers a real email via SMTP. When unset in development,
# the magic link is printed to the dev-server console so you can test the
# flow without setting up SMTP.
#
# Example (Gmail with an app password):
#   EMAIL_SERVER="smtp://user@gmail.com:APP_PASSWORD@smtp.gmail.com:587"
#   EMAIL_FROM="AgentHub <noreply@your-domain.com>"
#
# Example (Resend SMTP relay):
#   EMAIL_SERVER="smtp://resend:re_xxx@smtp.resend.com:587"
#   EMAIL_FROM="AgentHub <noreply@your-domain.com>"
EMAIL_SERVER=""
EMAIL_FROM=""

# Demo seed credentials
SEED_USER_EMAIL="demo@agenthub.dev"
SEED_USER_PASSWORD="demo1234"
