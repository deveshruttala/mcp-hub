# Database — defaults to local SQLite for instant MVP startup.
# Swap to Postgres by setting DATABASE_URL to a postgres:// URL and changing
# the provider in prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# NextAuth.js
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Optional Google OAuth (placeholder — leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Demo seed credentials
SEED_USER_EMAIL="demo@agenthub.dev"
SEED_USER_PASSWORD="demo1234"
